{
    "name": "lbhurtado/voucher",
    "description": "Digital voucher module for issuance, redemption, and lifecycle management",
    "type": "library",
    "license": "proprietary",
    "repositories": [
        {
            "type": "path",
            "url": "./../payment-gateway"
        }
    ],
    "authors": [
        {
            "name": "Lester Hurtado",
            "email": "lester@hurtado.ph"
        }
    ],
    "autoload": {
        "psr-4": {
            "LBHurtado\\Voucher\\": "src/",
            "LBHurtado\\Voucher\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LBHurtado\\Voucher\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LBHurtado\\Voucher\\VoucherServiceProvider"
            ]
        }
    },
    "require": {
        "3neti/cash": "^v1.0",
        "3neti/contact": "^v1.0",
        "3neti/wallet": "^v1.0",
        "3neti/laravel-model-input": "^v1.0",
        "3neti/settlement-envelope": "^v1.0",
        "brick/money": "^0.10.1",
        "frittenkeez/laravel-vouchers": "^0.6.0",
        "lbhurtado/payment-gateway": "dev-main",
        "lorisleiva/laravel-actions": "^2.9",
        "propaganistas/laravel-phone": "^6.0",
        "spatie/laravel-model-status": "^1.18",
        "spatie/laravel-tags": "^4.10",
        "spatie/laravel-medialibrary": "^11.17"
    },
    "suggest": {
        "lbhurtado/report-registry": "Required for built-in voucher report resolvers and YAML report drivers"
    },
    "require-dev": {
        "orchestra/testbench": "^10.3",
        "pestphp/pest": "^3.8"
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
