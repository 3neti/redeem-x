{
    "name": "lbhurtado/report-registry",
    "description": "Driver-based report registry with multi-format output and Handlebars templating",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Lester Hurtado",
            "email": "lester@hurtado.ph"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0",
        "illuminate/database": "^11.0 || ^12.0",
        "spatie/laravel-data": "^4.0",
        "symfony/yaml": "^7.0",
        "zordius/lightncandy": "^1.2"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "LBHurtado\\ReportRegistry\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LBHurtado\\ReportRegistry\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LBHurtado\\ReportRegistry\\ReportRegistryServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
