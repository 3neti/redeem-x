{
    "name": "lbhurtado/og-meta",
    "description": "Service-centric Open Graph meta tag generation with resolver-based architecture",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Lester Hurtado",
            "email": "lester@hurtado.ph"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0",
        "illuminate/http": "^11.0 || ^12.0",
        "illuminate/routing": "^11.0 || ^12.0",
        "spatie/laravel-data": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "LBHurtado\\OgMeta\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LBHurtado\\OgMeta\\OgMetaServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
